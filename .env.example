# Copy to .env.local for local development:
#   cp .env.example .env.local

# Required in production (set in Netlify → Site configuration → Environment variables)
ADMIN_PASSWORD=your-secure-admin-password

# Optional: bypass signup countdown during development (signups always open)
# SIGNUPS_UNLOCKED=true

# Optional: override unlock time for testing (ISO 8601 UTC)
# SIGNUP_UNLOCK_AT=2026-07-07T14:00:00.000Z
